# Django backend .env template
#
# Copy this file to .env and fill in the values for your environment.
#
# PRODUCTION: the only required variable is DOMAIN.
# DEV: leave DOMAIN unset — the app uses localhost defaults automatically.

# --------------------------------- Required --------------------------------- #
# Your public domain (e.g. "mydomain.com"). Setting this switches the app into
# production mode: DEBUG off, HTTPS-only cookies, and all host/CORS settings
# derived automatically. Leave unset for local development.
# DOMAIN=mydomain.com

# The secret key used to sign cookies and tokens. Must be set in production.
# Generate one with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# DJANGO_SECRET_KEY=your-secret-key-here

# --------------------------------- Database --------------------------------- #
# Optional — if unset the app falls back to SQLite (fine for dev/single-user).
# In production with docker-compose these are typically set by the compose file.
# POSTGRES_HOST=postgres
# POSTGRES_DB_NAME=django
# POSTGRES_USER=django
# POSTGRES_PASSWORD=django
# POSTGRES_PORT=5432

# ----------------------------------- Redis ---------------------------------- #
# Optional — defaults to localhost:6379/0.
# In production with docker-compose these are typically set by the compose file.
# REDIS_HOST=redis
# REDIS_PORT=6379
# REDIS_DB=0

# --------------------------------- Dev only --------------------------------- #
# These are only needed to override dev defaults (no DOMAIN set).

# Force debug mode on/off. Defaults to True in dev, False in production.
# DJANGO_DEBUG=True

# Comma-separated list of allowed hosts (dev default: localhost,127.0.0.1,django)
# DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,django

# Comma-separated list of trusted origins for CSRF and CORS
# (dev default: http://localhost:5173,http://localhost:4321)
# DJANGO_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4321

# Cookie domain (dev default: localhost)
# DJANGO_CSRF_COOKIE_DOMAIN=localhost
# DJANGO_SESSION_COOKIE_DOMAIN=localhost

# CSRF cookie name (default: csrftoken)
# DJANGO_CSRF_COOKIE_NAME=csrftoken

# ---------------------------------- Logging --------------------------------- #
# Log level for application loggers. Defaults to INFO.
# LOGGING_LOG_LEVEL=DEBUG
